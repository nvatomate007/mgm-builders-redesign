# MGM Builders — Environment Variables
# Copy this file to .env and fill in values for local development

# Manus storage proxy (required for dev server to serve logo and video)
# These are injected automatically when running inside Manus.
# For standalone deployment, replace /manus-storage/ paths in Home.tsx with direct asset URLs.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# No other secrets required for this static site.
# The contact form webhook URL is hardcoded in Home.tsx (WEBHOOK_URL constant).
